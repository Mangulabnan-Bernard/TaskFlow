# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (MySQL) — create the database first, e.g.  CREATE DATABASE taskflow;
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE   (XAMPP root has no password)
DATABASE_URL="mysql://root@localhost:3306/taskflow"

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
